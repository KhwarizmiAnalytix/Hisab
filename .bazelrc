# =============================================================================
# Quarisma Bazel Configuration
# =============================================================================
# Build flags, compiler options, and platform-specific settings
# Equivalent to CMake compiler flags and build type configurations
# =============================================================================

# =============================================================================
# Common Build Flags
# =============================================================================

# Enable WORKSPACE file for compatibility with Bazel 8
# WORKSPACE is disabled by default in Bazel 8, but we need it for local third-party dependencies
# This flag enables both MODULE.bazel (Bzlmod) and WORKSPACE to work together
build --enable_workspace

build --enable_platform_specific_config
build --experimental_repo_remote_exec

# Enable colored output
build --color=yes

# =============================================================================
# Responsiveness / hang-prevention flags
# =============================================================================
# Fail fast if the Bazel server doesn't respond within 30s
startup --connect_timeout_secs=30
# Show progress every 10s so a silent hang is immediately visible
build --show_progress_rate_limit=10
# Limit parallel jobs to avoid starving the system (uses all cores by default)
build --jobs=HOST_CPUS*.5
# Fetch timeout: abort if a single repository fetch takes more than 60s
build --experimental_repository_cache_hardlinks

# =============================================================================
# C++ Standard Selection
# =============================================================================
# --cxxopt=-std=c++XX is GCC/Clang syntax only; MSVC uses /std:c++XX.
# Each config uses --per_file_copt so the correct flag is applied per compiler.
# The windows platform config applies /std:c++XX via quarisma_copts() per-target,
# but these configs guard against leakage when --config=cxx20 etc. are passed
# explicitly on Windows.

# C++17
build:cxx17 --per_file_copt=Library/.*@-std=c++17
build:cxx17 --host_cxxopt=-std=c++17
build:cxx17:windows --per_file_copt=Library/.*@/std:c++17

# C++20
build:cxx20 --per_file_copt=Library/.*@-std=c++20
build:cxx20 --host_cxxopt=-std=c++20
build:cxx20:windows --per_file_copt=Library/.*@/std:c++20

# C++23
build:cxx23 --per_file_copt=Library/.*@-std=c++23
build:cxx23 --host_cxxopt=-std=c++23
build:cxx23:windows --per_file_copt=Library/.*@/std:c++23

# =============================================================================
# Optimization Levels
# =============================================================================

# Debug configuration (equivalent to CMAKE_BUILD_TYPE=Debug)
build:debug --compilation_mode=dbg
build:debug --copt=-O0
build:debug --copt=-g
build:debug --strip=never

# Release configuration (equivalent to CMAKE_BUILD_TYPE=Release)
build:release --compilation_mode=opt
build:release --copt=-O3
build:release --copt=-DNDEBUG
build:release --strip=always

# RelWithDebInfo configuration
build:relwithdebinfo --compilation_mode=opt
build:relwithdebinfo --copt=-O2
build:relwithdebinfo --copt=-g
build:relwithdebinfo --copt=-DNDEBUG
build:relwithdebinfo --strip=never

# =============================================================================
# Link Time Optimization (LTO)
# =============================================================================
build:lto --copt=-flto=thin
build:lto --linkopt=-flto=thin

# =============================================================================
# Vectorization Options (equivalent to QUARISMA_VECTORIZATION_TYPE)
# =============================================================================

# SSE vectorization
build:sse --copt=-msse
build:sse --copt=-msse2
build:sse --copt=-msse3
build:sse --copt=-mssse3
build:sse --copt=-msse4.1
build:sse --copt=-msse4.2

# AVX vectorization
build:avx --copt=-mavx
build:avx --copt=-msse4.2

# AVX2 vectorization (default)
build:avx2 --copt=-mavx2
build:avx2 --copt=-mfma
build:avx2 --copt=-mavx
build:avx2 --copt=-msse4.2

# AVX512 vectorization
build:avx512 --copt=-mavx512f
build:avx512 --copt=-mavx512cd
build:avx512 --copt=-mavx512bw
build:avx512 --copt=-mavx512dq
build:avx512 --copt=-mavx512vl

# =============================================================================
# Compiler-Specific Configurations
# =============================================================================
# Note: Bazel uses auto-detected toolchains (local_config_cc).
# These configs are primarily for documentation and future extensibility.
# The actual compiler is determined by the system's available toolchain.
# We do NOT add compiler-specific flags here to avoid conflicts with the
# actual compiler being used by Bazel's auto-detection.

# Clang compiler configuration
# --repo_env forces local_config_cc to select Clang instead of the system GCC default.
# C++ standard is NOT set here: on Linux/macOS it comes from the platform config
# (build:linux/build:macos --cxxopt=-std=c++20); on Windows the actual compiler is
# still cl.exe (repo_env only affects fetch), so Library targets get /std:c++20 via
# quarisma_copts(). Putting -std=c++20 here would pass a GCC/Clang flag to cl.exe.
build:clang --repo_env=CC=clang
build:clang --repo_env=CXX=clang++

# GCC compiler configuration (uses system GCC if available)
# C++ standard comes from build:linux --cxxopt=-std=c++20.

# MSVC compiler configuration (uses system MSVC if available)
# C++ standard for MSVC is set per-target via quarisma_copts() (/std:c++20).
# --cxxopt=-std=c++XX is GCC/Clang syntax; MSVC ignores it with D9002 warning.
build:msvc --copt=/W4

# Xcode configuration (macOS with Clang)
build:xcode --apple_platform_type=macos
build:xcode --cxxopt=-stdlib=libc++
build:xcode --cxxopt=-std=c++20

# =============================================================================
# Platform-Specific Configurations
# =============================================================================

# macOS specific settings
build:macos --cxxopt=-std=c++20
build:macos --host_cxxopt=-std=c++20
build:macos --cxxopt=-stdlib=libc++
build:macos --cxxopt=-faligned-allocation
build:macos --cxxopt=-mmacosx-version-min=10.13
build:macos --linkopt=-undefined
build:macos --linkopt=dynamic_lookup

# Linux specific settings
build:linux --cxxopt=-std=c++20
build:linux --host_cxxopt=-std=c++20
build:linux --cxxopt=-pthread
build:linux --linkopt=-pthread
build:linux --linkopt=-ldl
build:linux --linkopt=-lrt

# Windows specific settings (MSVC) — mirrors compiler_checks.cmake.
# Per-module MSVC flags (/std:c++XX, /Zc:__cplusplus, /bigobj, /utf-8, /wd*, /EHsc) are set
# per-target via quarisma_copts() in bazel/quarisma.bzl so Library targets are self-contained.
# ThirdParty/external targets need a C++17 baseline so they compile on MSVC (e.g. kineto).
# Use --per_file_copt to apply the baseline only to those paths, not to Library.
build:windows --per_file_copt=external/.*@/std:c++17
build:windows --per_file_copt=ThirdParty/.*@/std:c++17
build:windows --define=_WIN32_WINNT=0x0A00
build:windows --shell_executable=cmd.exe
# Bazel's Windows toolchain unconditionally implies `generate_pdb_file` which injects
# /DEBUG:FASTLINK. Modern MSVC dropped FASTLINK and emits LNK4315. We cannot disable
# the feature (Bazel 8 enforces unconditionally-implied features), so suppress the
# warning and override with /DEBUG:FULL so the linker uses full PDB generation.
build:windows --linkopt=/DEBUG:FULL
build:windows --linkopt=/ignore:4315

# =============================================================================
# Sanitizer Configurations
# =============================================================================

# Address Sanitizer — -O1 -g -fno-optimize-sibling-calls mirrors CMake sanitize.cmake
build:asan --strip=never
build:asan --copt=-fsanitize=address
build:asan --copt=-O1
build:asan --copt=-g
build:asan --copt=-fno-omit-frame-pointer
build:asan --copt=-fno-optimize-sibling-calls
build:asan --linkopt=-fsanitize=address

# Thread Sanitizer
build:tsan --strip=never
build:tsan --copt=-fsanitize=thread
build:tsan --copt=-O1
build:tsan --copt=-g
build:tsan --copt=-fno-omit-frame-pointer
build:tsan --copt=-fno-optimize-sibling-calls
build:tsan --linkopt=-fsanitize=thread

# Undefined Behavior Sanitizer
build:ubsan --strip=never
build:ubsan --copt=-fsanitize=undefined
build:ubsan --copt=-O1
build:ubsan --copt=-g
build:ubsan --copt=-fno-omit-frame-pointer
build:ubsan --copt=-fno-optimize-sibling-calls
build:ubsan --linkopt=-fsanitize=undefined

# Memory Sanitizer
build:msan --strip=never
build:msan --copt=-fsanitize=memory
build:msan --copt=-O1
build:msan --copt=-g
build:msan --copt=-fno-omit-frame-pointer
build:msan --copt=-fno-optimize-sibling-calls
build:msan --linkopt=-fsanitize=memory

# Leak Sanitizer (CMake sanitizer_enum=leak)
build:lsan --strip=never
build:lsan --copt=-fsanitize=leak
build:lsan --copt=-O1
build:lsan --copt=-g
build:lsan --copt=-fno-omit-frame-pointer
build:lsan --copt=-fno-optimize-sibling-calls
build:lsan --linkopt=-fsanitize=leak

# =============================================================================
# Feature Flags (CMake-aligned --define keys: core_*, memory_*, parallel_*, profiler_*, etc.)
# =============================================================================

# Enable CUDA support
build:cuda --define=memory_enable_cuda=true
build:cuda --crosstool_top=@local_config_cuda//crosstool:toolchain

# Enable HIP support
build:hip --define=memory_enable_hip=true

# Enable OpenMP (parallel backend + compile flags)
build:openmp --define=parallel_enable_openmp=true --copt=-fopenmp --linkopt=-fopenmp

# Enable TBB (Memory scalable allocator + Parallel backend; mirrors one-shot enable_tbb usage)
build:tbb --define=memory_enable_tbb=true --define=parallel_enable_tbb=true

# Enable MKL
build:mkl --define=core_enable_mkl=true

# NUMA / memkind (MEMORY_HAS_* — mirrors CMake MEMORY_ENABLE_NUMA / MEMORY_ENABLE_MEMKIND)
build:numa --define=memory_enable_numa=true
build:memkind --define=memory_enable_memkind=true

# Enable mimalloc
build:mimalloc --define=memory_enable_mimalloc=true

# Enable magic_enum
build:magic_enum --define=core_enable_magic_enum=true

# Enable Kineto profiling
# Note: Kineto config also enables native profiler for compatibility with tests
build:kineto --define=profiler_type=kineto --define=profiler_enable_kineto=true

# Enable native profiler
build:native_profiler --define=profiler_type=native

# Enable ITT profiling
build:itt --define=profiler_type=itt --define=profiler_enable_itt=true

# Enable LU pivoting
build:lu_pivoting --define=core_lu_pivoting=true

# Enable Sobol 1111 dimensions
build:sobol_1111 --define=core_sobol_1111=true

# Enzyme AD — mirrors CMake CORE_ENABLE_ENZYME + Enzyme::enzyme interface target.
# Enables QUARISMA_HAS_ENZYME=1 define and includes TestEnzymeAD.cpp in tests.
#
# The Enzyme LLVM plugin path cannot be auto-discovered in Bazel (CMake does this at
# configure time via Cmake/tools/enzyme.cmake). Add --per_file_copt in .bazelrc.user,
# restricting -fpass-plugin to Library/* only — equivalent to CMake's PRIVATE linkage
# which prevents the Clang-only flag from leaking to GCC-compiled third-party targets:
#   build:enzyme --per_file_copt=Library/.*@-fpass-plugin=/path/to/LLDEnzyme-XX.so
#
# DO NOT use global --copt/-linkopt: third-party targets (benchmark, etc.) may use
# GCC which rejects -fpass-plugin. --per_file_copt matches CMake's PRIVATE behaviour.
#
# quarisma_enzyme_copts()/quarisma_enzyme_linkopts() in //bazel:quarisma.bzl mark
# the structural intent; the actual flag is user-supplied via .bazelrc.user.
#
# Scripts/setup_bazel.py with an "enzyme" token auto-discovers the plugin (same search
# as CMake enzyme.cmake) and passes --per_file_copt + --linkopt. For raw `bazel` invokes,
# set ENZYME_PLUGIN_PATH or add the lines from the comment block above to .bazelrc.user.
build:enzyme --define=core_enable_enzyme=true

# =============================================================================
# Testing Configuration
# =============================================================================
test --test_output=errors
test --test_summary=detailed
# Kill individual tests that hang (5 minutes per test)
test --test_timeout=300

# Enable Google Test
build:gtest --define=enable_gtest=true

# Enable Google Benchmark
build:benchmark --define=enable_benchmark=true

# =============================================================================
# Code Coverage
# =============================================================================
coverage --combined_report=lcov
coverage --instrument_test_targets
# Note: --experimental_use_llvm_covmap is not supported on Windows/MSVC and
# may cause hangs. Enable via --config=llvm_coverage on Linux/macOS with Clang.
build:llvm_coverage --experimental_use_llvm_covmap

# =============================================================================
# Logging Backend Selection
# =============================================================================
build:logging_glog --define=logging_backend=glog
build:logging_loguru --define=logging_backend=loguru
build:logging_native --define=logging_backend=native

# =============================================================================
# GPU Allocation Strategy
# =============================================================================
build:gpu_alloc_sync --define=memory_gpu_alloc=sync
build:gpu_alloc_async --define=memory_gpu_alloc=async
build:gpu_alloc_pool_async --define=memory_gpu_alloc=pool_async

# =============================================================================
# Bazel --batch (manual use)
# =============================================================================
# `--batch` is a startup option. If a server is already running from a prior `bazel` command
# without `--batch`, the next `bazel --batch ...` may warn and restart the server. Run
# `bazel shutdown` first, or use:  bazel shutdown; bazel --batch test ...
# Scripts/setup_bazel.py with token `batch` runs shutdown before build/test.

# =============================================================================
# CMake-equivalent defaults
# =============================================================================
# Defaults: VECTORIZATION_TYPE=avx2; all modules’ *ENABLE_BENCHMARK=ON (vectorization + project-wide).
build --define=vectorization_type=avx2 --define=vectorization_enable_benchmark=true --define=enable_benchmark=true
#
# Feature defaults (mimalloc, magic_enum, KINETO profiler, LOGURU, Sobol 1111, POOL_ASYNC GPU
# alloc) are applied in //bazel:*.bzl — plain `bazel build //...` matches root CMakeLists.txt
# without extra --define. Opt out with e.g. --define=memory_enable_mimalloc=false / disable_sobol_1111.
#
# Compiler-wrapper caching (ccache/sccache/buildcache) is configured in CMake per library target via
# LOGGING_ENABLE_CACHE + LOGGING_CACHE_BACKEND (and MEMORY_*, CORE_*, PARALLEL_*, PROFILER_*). There
# are no legacy PROJECT_* cache defines in Bazel; use remote/cache or a host toolchain wrapper if needed.

# =============================================================================
# Default Configuration
# =============================================================================
# Import user-specific configuration
try-import %workspace%/.bazelrc.user
