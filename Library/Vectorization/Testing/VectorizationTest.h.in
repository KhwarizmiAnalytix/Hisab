        std::cerr << "EXPECT_EQ failed: " << #expected << " != " << #actual << " at "     \
                  << __FILE__ << ":" << __LINE__ << std::endl;                             \
      }                                                                                    \
    } while (0)

#  define EXPECT_NE(expected, actual)                                                      \
    do                                                                                     \
    {                                                                                      \
      if ((expected) == (actual))                                                          \
      {                                                                                    \
        std::cerr << "EXPECT_NE failed: " << #expected << " == " << #actual << " at "     \
                  << __FILE__ << ":" << __LINE__ << std::endl;                             \
      }                                                                                    \
    } while (0)

#  define EXPECT_LT(val1, val2)                                                            \
