      }                                                                                    \
    } while (0)

#  define ASSERT_TRUE(condition)                                                           \
    do                                                                                     \
    {                                                                                      \
      if (!(condition))                                                                    \
      {                                                                                    \
        std::cerr << "ASSERT_TRUE failed: " << #condition << " at " << __FILE__ << ":"    \
                  << __LINE__ << std::endl;                                                \
        throw std::runtime_error("Assertion failed: " #condition);                        \
      }                                                                                    \
    } while (0)

#  define ASSERT_FALSE(condition)                                                          \
    do                                                                                     \
    {                                                                                      \
      if (condition)                                                                       \
