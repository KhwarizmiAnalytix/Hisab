      }                                                                                    \
    } while (0)

#  define EXPECT_NEAR(expected, actual, tolerance)                                         \
    do                                                                                     \
    {                                                                                      \
      if (std::abs((expected) - (actual)) > tolerance)                                     \
      {                                                                                    \
        std::cerr << "EXPECT_NEAR failed: " << #expected << " != " << #actual << " at "    \
                  << __FILE__ << ":" << __LINE__ << std::endl;                             \
      }                                                                                    \
    } while (0)

#  define EXPECT_EQ(expected, actual)                                                      \
