load("//bazel:logging.bzl", "logging_copts", "logging_defines", "logging_linkopts")

package(default_visibility = ["//visibility:public"])

cc_test(
    name = "LoggingCxxTests",
    size = "large",
    timeout = "long",
    srcs = glob(
        ["Test*.cpp"],
        exclude = ["TestLoggerDisableSignalHandler.cpp"],
        allow_empty = True,
    ),
    copts = logging_copts(),
    defines = logging_defines() + [
        "LOGGING_GOOGLE_TEST",
        "USE_GTEST",
        "_VARIADIC_MAX=10",
        "LOGGING_HAS_GTEST=1",
    ],
    includes = ["."],
    linkopts = logging_linkopts(),
    deps = [
        "//Library/Logging:Logging",
        "//Library/Logging/Testing:loggingTest_header",
        "@com_google_googletest//:gtest",
        "@com_google_googletest//:gtest_main",
        "@loguru//:loguru",
    ],
)
