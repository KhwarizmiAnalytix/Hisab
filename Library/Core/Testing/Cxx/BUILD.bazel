# =============================================================================
# Quarisma Core Library Tests BUILD Configuration
# =============================================================================
# Test targets for Core library using GoogleTest
# Equivalent to Library/Core/Testing/Cxx/CMakeLists.txt (glob + conditional excludes)
# =============================================================================

load("//bazel:quarisma.bzl", "quarisma_copts", "quarisma_defines", "quarisma_enzyme_copts", "quarisma_enzyme_linkopts", "quarisma_linkopts")

package(default_visibility = ["//visibility:public"])

# Base tests: all Test*.cpp except always-excluded and GPU/CUDA/HIP (added back via select).
_CORE_TEST_SRCS = glob(
    ["Test*.cpp"],
    exclude = [
        "TestLoggerDisableSignalHandler.cpp",
        # TestEnzymeAD.cpp added back via select when Enzyme is enabled (matches CMake QUARISMA_ENABLE_ENZYME)
        "TestEnzymeAD.cpp",
        "TestGpu*.cpp",
        "TestGPU*.cpp",
        "TestCuda*.cpp",
        "TestHip*.cpp",
    ],
) + select({
    "//bazel:enable_enzyme": glob(["TestEnzymeAD.cpp"], allow_empty = True),
    "//conditions:default": [],
}) + select({
    "//bazel:enable_cuda": glob(
        [
            "TestGpu*.cpp",
            "TestGPU*.cpp",
            "TestCuda*.cpp",
        ],
        allow_empty = True,
    ),
    "//conditions:default": [],
}) + select({
    "//bazel:enable_hip": glob(["TestHip*.cpp"], allow_empty = True),
    "//conditions:default": [],
})

# =============================================================================
# Core Tests Target
# =============================================================================

cc_test(
    name = "CoreCxxTests",
    size = "large",
    timeout = "long",
    srcs = _CORE_TEST_SRCS,
    copts = quarisma_copts() + quarisma_enzyme_copts(),
    defines = quarisma_defines() + [
        "QUARISMA_GOOGLE_TEST",
        "USE_GTEST",
        "_VARIADIC_MAX=10",
        "QUARISMA_HAS_GTEST=1",
    ] + select({
        "//bazel:enable_cuda": ["QUARISMA_HAS_CUDA=1"],
        "//conditions:default": ["QUARISMA_HAS_CUDA=0"],
    }) + select({
        "//bazel:enable_hip": ["QUARISMA_HAS_HIP=1"],
        "//conditions:default": ["QUARISMA_HAS_HIP=0"],
    }),
    includes = ["."],
    linkopts = quarisma_linkopts() + quarisma_enzyme_linkopts(),
    deps = [
        "//Library/Core:Core",
        "//Library/Core/Testing:quarismaTest_header",
        "@com_google_googletest//:gtest",
        "@com_google_googletest//:gtest_main",
    ],
)

# =============================================================================
# Benchmark Targets (matches CMake QUARISMA_ENABLE_BENCHMARK targets)
# Note: BenchmarkParallel has moved to //Library/Parallel/Testing/Cxx:BenchmarkParallel
# Build with: bazel build //Library/Core/Testing/Cxx:BenchmarkAllocatorComparison
#             bazel build //Library/Core/Testing/Cxx:BenchmarkCPUMemoryAllocators
# =============================================================================

cc_binary(
    name = "BenchmarkAllocatorComparison",
    srcs = ["BenchmarkAllocatorComparison.cpp"],
    copts = quarisma_copts(),
    defines = quarisma_defines(),
    linkopts = quarisma_linkopts(),
    deps = [
        "//Library/Core:Core",
        "@com_google_benchmark//:benchmark",
        "@com_google_benchmark//:benchmark_main",
    ],
)

cc_binary(
    name = "BenchmarkCPUMemoryAllocators",
    srcs = ["BenchmarkCPUMemoryAllocators.cpp"],
    copts = quarisma_copts(),
    defines = quarisma_defines(),
    linkopts = quarisma_linkopts(),
    deps = [
        "//Library/Core:Core",
        "@com_google_benchmark//:benchmark",
        "@com_google_benchmark//:benchmark_main",
    ],
)
