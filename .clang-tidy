---
HeaderFilterRegex: '^(?!.*(ThirdParty|experimental|Experimental)).*'  # Exclude third party and experimental folders from checks
Checks: "-*,\
bugprone-*,\
-bugprone-unchecked-optional-access,\
-bugprone-exception-escape,\
-bugprone-narrowing-conversions,\
-bugprone-easily-swappable-parameters,\
-bugprone-macro-parentheses,\
# New: CRTP base accessibility pattern used intentionally throughout the library
-bugprone-crtp-constructor-accessibility,\
# New: intentional widening multiplications in numeric/SIMD code
-bugprone-implicit-widening-of-multiplication-result,\
# New: seeding patterns are controlled by the caller
-bugprone-random-generator-seed,\
# New: internal header guards use reserved identifiers by convention
-bugprone-reserved-identifier,\
# New: const-ref return from parameter is an intentional design pattern here
-bugprone-return-const-ref-from-parameter,\
# New: std namespace specializations (e.g. std::hash) are explicitly intended
-bugprone-std-namespace-modification,\
# New: static initializers with exceptions are acceptable in this codebase
-bugprone-throwing-static-initialization,\
# New: self-assignment handled at a higher level or intentionally omitted
-bugprone-unhandled-self-assignment,\
modernize-*,\
-modernize-use-ranges,\
-modernize-use-trailing-return-type,\
-modernize-avoid-c-arrays,\
-modernize-type-traits,\
-modernize-concat-nested-namespaces,\
-modernize-use-designated-initializers,\
-modernize-use-integer-sign-comparison,\
-modernize-use-equals-delete,\
-modernize-use-nodiscard,\
-modernize-use-default-member-init,\
# New: C-style casts used in low-level/interop code intentionally
-modernize-avoid-c-style-cast,\
# New: variadic functions used in logging/formatting interfaces
-modernize-avoid-variadic-functions,\
# New: macros kept as macros for cross-platform compatibility
-modernize-macro-to-enum,\
# New: pass-by-value would break existing API contracts
-modernize-pass-by-value,\
# New: explicit construction preferred over braced-init-list for clarity
-modernize-return-braced-init-list,\
# New: single-argument static_assert kept for older compiler compatibility
-modernize-unary-static-assert,\
# New: requires-clauses migration deferred to a dedicated refactor pass
-modernize-use-constraints,\
# New: explicitly defaulted functions require broader audit before enabling
-modernize-use-equals-default,\
# New: virtual override annotations pending a dedicated refactor pass
-modernize-use-override,\
# New: scoped_lock migration deferred; existing lock usage is correct
-modernize-use-scoped-lock,\
# New: typedef/using migration deferred to a dedicated refactor pass
-modernize-use-using,\
readability-*,\
-readability-suspicious-call-argument,\
-readability-deleted-default,\
-readability-function-cognitive-complexity,\
-readability-avoid-unconditional-preprocessor-if,\
-readability-avoid-return-with-void-value,\
-readability-avoid-nested-conditional-operator,\
-readability-static-accessed-through-instance,\
-readability-uppercase-literal-suffix,\
-readability-magic-numbers,\
-readability-identifier-length,\
-readability-simplify-boolean-expr,\
-readability-convert-member-functions-to-static,\
-readability-use-concise-preprocessor-directives,\
-readability-avoid-const-params-in-decls,\
-readability-braces-around-statements,\
-readability-container-contains,\
-readability-else-after-return,\
-readability-implicit-bool-conversion,\
-readability-make-member-function-const,\
-readability-math-missing-parentheses,\
-readability-named-parameter,\
-readability-qualified-auto,\
-readability-redundant-access-specifiers,\
-readability-redundant-declaration,\
-readability-redundant-inline-specifier,\
-readability-redundant-member-init,\
-readability-redundant-parentheses,\
-readability-redundant-typename,\
misc-*,\
-misc-include-cleaner,\
-misc-use-anonymous-namespace,\
-misc-no-recursion,\
-misc-non-private-member-variables-in-classes,\
-misc-header-include-cycle,\
-misc-const-correctness,\
-misc-multiple-inheritance,\
-misc-unconventional-assign-operator,\
-misc-unused-parameters,\
-misc-use-internal-linkage,\
"
CheckOptions:
  - key: readability-identifier-length.MinimumVariableNameLength
    value: '2'
  - key: readability-identifier-length.ParameterNameLength
    value: '2'
#WarningsAsErrors: "*"
UseColor: true  # Enable colored output
...
